<UserControl
    d:DesignWidth="1200"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.WelcomeFlow.Welcome.WelcomePageView"
    x:DataType="welcome:WelcomePageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:CoffeePeek.Client.App.Resources.Lang"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:welcome="clr-namespace:CoffeePeek.Client.App.ViewModels.WelcomeFlow.Welcome"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource AuthPageBackgroundBrush}">
        <Ellipse
            Height="520"
            HorizontalAlignment="Left"
            IsHitTestVisible="False"
            Margin="-140,-160,0,0"
            Opacity="0.07"
            VerticalAlignment="Top"
            Width="520">
            <Ellipse.Fill>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse
            Height="380"
            HorizontalAlignment="Right"
            IsHitTestVisible="False"
            Margin="0,320,-100,0"
            Opacity="0.05"
            VerticalAlignment="Top"
            Width="380">
            <Ellipse.Fill>
                <SolidColorBrush Color="{DynamicResource PrimaryColor}" />
            </Ellipse.Fill>
        </Ellipse>

        <Button
            Background="{DynamicResource SurfaceLowestBrush}"
            BorderThickness="0"
            Command="{Binding ToggleThemeCommand}"
            CornerRadius="{StaticResource PillRadius}"
            HorizontalAlignment="Right"
            Margin="0,20,20,0"
            Padding="12"
            ToolTip.Tip="{x:Static lang:Resources.Auth_ThemeToggle}"
            VerticalAlignment="Top"
            ZIndex="40">
            <Panel Height="22" Width="22">
                <PathIcon
                    Data="{StaticResource ThemeMoonIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding ThemeShowsSunIcon}"
                    Width="22" />
                <PathIcon
                    Data="{StaticResource ThemeSunIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding !ThemeShowsSunIcon}"
                    Width="22" />
            </Panel>
        </Button>

        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            ZIndex="5">
            <StackPanel
                HorizontalAlignment="Center"
                Margin="24,20,24,40"
                MaxWidth="1180"
                Spacing="40">

                <!--  Header  -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="22"
                            FontWeight="Normal"
                            Foreground="{DynamicResource OnSurfaceBrush}"
                            Text="{x:Static lang:Resources.Auth_BrandCoffee}"
                            VerticalAlignment="Center" />
                        <TextBlock
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="22"
                            FontWeight="Normal"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Text="{x:Static lang:Resources.Auth_BrandPeek}"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="28"
                        VerticalAlignment="Center">
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="15"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Text="{x:Static lang:Resources.WelcomePage_Nav_Explore}" />
                            <Border
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="1"
                                Height="2" />
                        </StackPanel>
                        <Button
                            Classes="Transparent"
                            Content="{x:Static lang:Resources.WelcomePage_Nav_Cafes}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="15"
                            FontWeight="Normal"
                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                            IsEnabled="False"
                            Padding="0"
                            VerticalAlignment="Center" />
                        <Button
                            Classes="Transparent"
                            Content="{x:Static lang:Resources.WelcomePage_Nav_Community}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="15"
                            FontWeight="Normal"
                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                            IsEnabled="False"
                            Padding="0"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                        <Button
                            Classes="Transparent"
                            Command="{Binding GoToLoginCommand}"
                            Content="{x:Static lang:Resources.WelcomePage_LogInHeader}"
                            CornerRadius="{StaticResource PillRadius}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="14"
                            FontWeight="Normal"
                            Foreground="{DynamicResource OnSurfaceBrush}"
                            Padding="16,10"
                            VerticalAlignment="Center" />
                        <Button
                            Command="{Binding GoToRegisterCommand}"
                            Content="{x:Static lang:Resources.WelcomePage_SignUpHeader}"
                            CornerRadius="{StaticResource PillRadius}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="14"
                            FontWeight="Normal"
                            Padding="22,12"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!--  Hero  -->
                <Border
                    Background="{DynamicResource AuthCardBackgroundBrush}"
                    CornerRadius="{StaticResource SuperLargeRadius}"
                    Padding="40,36,0,36">
                    <Grid ColumnDefinitions="*,1.1*">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,28,0"
                            Spacing="20"
                            VerticalAlignment="Center">
                            <Border
                                Background="{DynamicResource SecondaryLightBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource PillRadius}"
                                HorizontalAlignment="Left"
                                Padding="14,8">
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="11"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    LetterSpacing="0.06"
                                    Text="{x:Static lang:Resources.WelcomePage_HeroBadge}" />
                            </Border>
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="40"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                LetterSpacing="-0.02"
                                LineHeight="48"
                                Text="{x:Static lang:Resources.WelcomePage_HeroHeadline}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="16"
                                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                LineHeight="24"
                                MaxWidth="520"
                                Text="{x:Static lang:Resources.WelcomePage_HeroDescription}"
                                TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <Button
                                    Command="{Binding GoToRegisterCommand}"
                                    Content="{x:Static lang:Resources.WelcomePage_GetStarted}"
                                    CornerRadius="{StaticResource PillRadius}"
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="16"
                                    FontWeight="Normal"
                                    MinHeight="52"
                                    Padding="28,14" />
                                <Button
                                    Classes="Secondary"
                                    Content="{x:Static lang:Resources.WelcomePage_ViewGallery}"
                                    CornerRadius="{StaticResource PillRadius}"
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="16"
                                    FontWeight="Normal"
                                    IsEnabled="False"
                                    MinHeight="52"
                                    Padding="28,14" />
                            </StackPanel>
                        </StackPanel>

                        <Border
                            ClipToBounds="True"
                            CornerRadius="0,40,40,0"
                            Grid.Column="1"
                            Margin="0,8,8,8"
                            MinHeight="280">
                            <Panel>
                                <Image
                                    HorizontalAlignment="Right"
                                    Source="avares://CoffeePeek.Client.App/Assets/Welcome/hero-latte.jpg"
                                    Stretch="UniformToFill"
                                    VerticalAlignment="Center" />
                                <Rectangle IsHitTestVisible="False">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#00000000" Offset="0.55" />
                                            <GradientStop Color="{DynamicResource SurfaceColor}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Panel>
                        </Border>
                    </Grid>
                </Border>

                <!--  Social proof pill  -->
                <Border
                    Background="{DynamicResource SurfaceLowestBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource PillRadius}"
                    HorizontalAlignment="Right"
                    Margin="0,16,32,0"
                    Padding="14,10"
                    ZIndex="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Panel Height="28" Width="72">
                            <Ellipse
                                Fill="{DynamicResource PrimaryBrush}"
                                Height="28"
                                Margin="0,0,44,0"
                                Stroke="{DynamicResource SurfaceLowestBrush}"
                                StrokeThickness="2"
                                VerticalAlignment="Center"
                                Width="28" />
                            <Ellipse
                                Height="28"
                                Margin="22,0,22,0"
                                Stroke="{DynamicResource SurfaceLowestBrush}"
                                StrokeThickness="2"
                                VerticalAlignment="Center"
                                Width="28">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{DynamicResource PrimaryContainerColor}" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse
                                Fill="{DynamicResource SecondaryLightBrush}"
                                Height="28"
                                Margin="44,0,0,0"
                                Stroke="{DynamicResource SurfaceLowestBrush}"
                                StrokeThickness="2"
                                VerticalAlignment="Center"
                                Width="28" />
                        </Panel>
                        <TextBlock
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="13"
                            FontWeight="Normal"
                            Foreground="{DynamicResource OnSurfaceBrush}"
                            Text="{x:Static lang:Resources.WelcomePage_SocialProof}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!--  Bento  -->
                <Grid RowDefinitions="Auto,*">
                    <TextBlock
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="28"
                        FontWeight="Normal"
                        Foreground="{DynamicResource OnSurfaceBrush}"
                        Grid.Row="0"
                        Margin="0,8,0,12"
                        Text="{x:Static lang:Resources.WelcomePage_Section_FeaturesTitle}" />
                    <Grid
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="16"
                        Grid.Row="1"
                        RowDefinitions="220,220"
                        RowSpacing="16">
                        <!--  Roasters  -->
                        <Border
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            CornerRadius="{StaticResource LargeRadius}"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="0"
                            Padding="28,24">
                            <Grid ColumnDefinitions="*,180">
                                <StackPanel Spacing="12" VerticalAlignment="Center">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="22"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{x:Static lang:Resources.WelcomePage_Bento_RoastersTitle}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="14"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LineHeight="20"
                                        Text="{x:Static lang:Resources.WelcomePage_Bento_RoastersDesc}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Classes="Transparent"
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="12"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        HorizontalAlignment="Left"
                                        IsEnabled="False"
                                        LetterSpacing="0.08"
                                        Padding="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Static lang:Resources.WelcomePage_Bento_RoastersCta}" />
                                            <PathIcon
                                                Data="{StaticResource ArrowRightIcon}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Height="14"
                                                Width="14" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Border
                                    Background="{DynamicResource SurfaceContainerHighBrush}"
                                    ClipToBounds="True"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    Grid.Column="1"
                                    Opacity="0.85">
                                    <PathIcon
                                        Data="{StaticResource CoffeeBrandIcon}"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        Height="80"
                                        HorizontalAlignment="Center"
                                        Opacity="0.45"
                                        VerticalAlignment="Center"
                                        Width="80" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Brewing  -->
                        <Border
                            Background="{DynamicResource SecondaryLightBrush}"
                            CornerRadius="{StaticResource LargeRadius}"
                            Grid.Column="2"
                            Grid.Row="0"
                            Padding="22">
                            <StackPanel Spacing="14" VerticalAlignment="Center">
                                <Border
                                    Background="{DynamicResource OutlineVariantGhostBrush}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    HorizontalAlignment="Left"
                                    Padding="12">
                                    <PathIcon
                                        Data="{StaticResource BookClosedIcon}"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Height="26"
                                        Width="26" />
                                </Border>
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="20"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    Text="{x:Static lang:Resources.WelcomePage_Bento_BrewTitle}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="14"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    LineHeight="20"
                                    Opacity="0.9"
                                    Text="{x:Static lang:Resources.WelcomePage_Bento_BrewDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!--  Community  -->
                        <Border
                            Background="{DynamicResource SurfaceContainerHighBrush}"
                            CornerRadius="{StaticResource LargeRadius}"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="1"
                            Padding="28,24">
                            <Grid ColumnDefinitions="*,200">
                                <StackPanel Spacing="12" VerticalAlignment="Center">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="22"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{x:Static lang:Resources.WelcomePage_Bento_CommunityTitle}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="14"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LineHeight="20"
                                        MaxWidth="420"
                                        Text="{x:Static lang:Resources.WelcomePage_Bento_CommunityDesc}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <UniformGrid
                                    Columns="2"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Rows="2"
                                    VerticalAlignment="Center">
                                    <Border
                                        Background="{DynamicResource SurfaceLowestBrush}"
                                        CornerRadius="{StaticResource PillRadius}"
                                        HorizontalAlignment="Stretch"
                                        Margin="6"
                                        Padding="14">
                                        <PathIcon
                                            Data="{StaticResource ChatBubbleIcon}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            Width="22" />
                                    </Border>
                                    <Border
                                        Background="{DynamicResource SurfaceLowestBrush}"
                                        CornerRadius="{StaticResource PillRadius}"
                                        HorizontalAlignment="Stretch"
                                        Margin="6"
                                        Padding="14">
                                        <PathIcon
                                            Data="{StaticResource PeopleGroupIcon}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            Width="22" />
                                    </Border>
                                    <Border
                                        Background="{DynamicResource SurfaceLowestBrush}"
                                        CornerRadius="{StaticResource PillRadius}"
                                        HorizontalAlignment="Stretch"
                                        Margin="6"
                                        Padding="14">
                                        <PathIcon
                                            Data="{StaticResource AwardIcon}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            Width="22" />
                                    </Border>
                                    <Border
                                        Background="{DynamicResource SurfaceLowestBrush}"
                                        CornerRadius="{StaticResource PillRadius}"
                                        HorizontalAlignment="Stretch"
                                        Margin="6"
                                        Padding="14">
                                        <PathIcon
                                            Data="{StaticResource HeartIcon}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Height="22"
                                            HorizontalAlignment="Center"
                                            Width="22" />
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!--  Perks  -->
                        <Border
                            Background="{DynamicResource SurfaceContainerBrush}"
                            CornerRadius="{StaticResource LargeRadius}"
                            Grid.Column="2"
                            Grid.Row="1"
                            Padding="22">
                            <StackPanel Spacing="14" VerticalAlignment="Center">
                                <Border
                                    Background="{DynamicResource PrimaryGoldTransparent}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    HorizontalAlignment="Left"
                                    Padding="12">
                                    <PathIcon
                                        Data="{StaticResource MonitorIcon}"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Height="26"
                                        Width="26" />
                                </Border>
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="20"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    Text="{x:Static lang:Resources.WelcomePage_Bento_PerksTitle}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="14"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    LineHeight="20"
                                    Text="{x:Static lang:Resources.WelcomePage_Bento_PerksDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!--  Search  -->
                <StackPanel
                    HorizontalAlignment="Stretch"
                    MaxWidth="720"
                    Spacing="14">
                    <TextBox
                        Classes="form-field"
                        Focusable="False"
                        FontSize="16"
                        IsReadOnly="True"
                        IsHitTestVisible="False"
                        IsTabStop="False"
                        MinHeight="52"
                        PlaceholderText="{x:Static lang:Resources.WelcomePage_SearchPlaceholder}">
                        <TextBox.InnerLeftContent>
                            <PathIcon
                                Data="{StaticResource SearchIcon}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Height="22"
                                Margin="16,0,8,0"
                                VerticalAlignment="Center"
                                Width="22" />
                        </TextBox.InnerLeftContent>
                    </TextBox>
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Border
                            Background="{DynamicResource PrimaryGoldTransparent}"
                            CornerRadius="{StaticResource PillRadius}"
                            IsHitTestVisible="False"
                            Padding="12,8">
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="12"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Text="{x:Static lang:Resources.WelcomePage_TrendingChip1}" />
                        </Border>
                        <Border
                            Background="{DynamicResource PrimaryGoldTransparent}"
                            CornerRadius="{StaticResource PillRadius}"
                            IsHitTestVisible="False"
                            Padding="12,8">
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="12"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Text="{x:Static lang:Resources.WelcomePage_TrendingChip2}" />
                        </Border>
                        <Border
                            Background="{DynamicResource PrimaryGoldTransparent}"
                            CornerRadius="{StaticResource PillRadius}"
                            IsHitTestVisible="False"
                            Padding="12,8">
                            <TextBlock
                                FontFamily="{StaticResource RFDewiExpanded}"
                                FontSize="12"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Text="{x:Static lang:Resources.WelcomePage_TrendingChip3}" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!--  Footer  -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,16,0,0">
                    <TextBlock
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="13"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        Grid.Column="0"
                        Text="{x:Static lang:Resources.WelcomePage_Footer_Copyright}"
                        VerticalAlignment="Center" />
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="20"
                        VerticalAlignment="Center">
                        <Button
                            Classes="Transparent"
                            Content="{x:Static lang:Resources.WelcomePage_Footer_Privacy}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="13"
                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                            IsEnabled="False"
                            Padding="0" />
                        <Button
                            Classes="Transparent"
                            Content="{x:Static lang:Resources.WelcomePage_Footer_Terms}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="13"
                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                            IsEnabled="False"
                            Padding="0" />
                        <Button
                            Classes="Transparent"
                            Content="{x:Static lang:Resources.WelcomePage_Footer_Contact}"
                            FontFamily="{StaticResource RFDewiExpanded}"
                            FontSize="13"
                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                            IsEnabled="False"
                            Padding="0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
