<UserControl
    d:DesignHeight="900"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.WelcomeFlow.Auth.RegisterView"
    x:DataType="auth:RegisterViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:auth="clr-namespace:CoffeePeek.Client.App.ViewModels.WelcomeFlow.Auth"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:CoffeePeek.Client.App.Resources.Lang"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            Background="{DynamicResource SurfaceLowestBrush}"
            BorderThickness="0"
            Command="{Binding ToggleThemeCommand}"
            CornerRadius="9999"
            Grid.Row="0"
            HorizontalAlignment="Right"
            Margin="0,16,16,0"
            Padding="12"
            ToolTip.Tip="{x:Static lang:Resources.Auth_ThemeToggle}"
            VerticalAlignment="Top"
            ZIndex="30">
            <Panel Height="22" Width="22">
                <PathIcon
                    Data="{StaticResource ThemeMoonIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding ThemeShowsSunIcon}"
                    Width="22" />
                <PathIcon
                    Data="{StaticResource ThemeSunIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding !ThemeShowsSunIcon}"
                    Width="22" />
            </Panel>
        </Button>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            ZIndex="5">
            <Border
                HorizontalAlignment="Center"
                Margin="24,56,24,32"
                MaxWidth="960"
                MinWidth="320"
                VerticalAlignment="Center">
                <Border
                    Background="{DynamicResource SurfaceLowestBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="{StaticResource LargeRadius}">
                    <Grid ColumnDefinitions="*,*" MinHeight="560">
                        <!--  Left: hero (email vs details)  -->
                        <Panel Grid.Column="0" MinWidth="280">
                            <Panel IsVisible="{Binding IsEmailStep}">
                                <Image
                                    HorizontalAlignment="Center"
                                    Source="avares://CoffeePeek.Client.App/Assets/Auth/email-hero.jpg"
                                    Stretch="UniformToFill"
                                    VerticalAlignment="Center" />
                                <Rectangle IsHitTestVisible="False" VerticalAlignment="Stretch">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush EndPoint="50%,100%" StartPoint="50%,0%">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#44000000" Offset="0.5" />
                                            <GradientStop Color="#88000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <StackPanel
                                    Margin="28,0,28,32"
                                    Spacing="10"
                                    VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="22"
                                            FontWeight="Normal"
                                            Foreground="White"
                                            Text="{x:Static lang:Resources.Auth_BrandCoffee}" />
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="22"
                                            FontWeight="Normal"
                                            Text="{x:Static lang:Resources.Auth_BrandPeek}">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{DynamicResource PrimaryContainerColor}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="14"
                                        Foreground="#E8FFFFFF"
                                        LineHeight="20"
                                        Text="{x:Static lang:Resources.Auth_EmailHeroTagline}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Panel>
                            <Panel IsVisible="{Binding IsDetailsStep}">
                                <Image
                                    HorizontalAlignment="Center"
                                    Source="avares://CoffeePeek.Client.App/Assets/Auth/register-hero.jpg"
                                    Stretch="UniformToFill"
                                    VerticalAlignment="Center" />
                                <Rectangle IsHitTestVisible="False" VerticalAlignment="Stretch">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush EndPoint="50%,100%" StartPoint="50%,0%">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#55000000" Offset="0.45" />
                                            <GradientStop Color="#99000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <StackPanel
                                    Margin="28,0,28,32"
                                    Spacing="12"
                                    VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="22"
                                            FontWeight="Normal"
                                            Foreground="White"
                                            Text="{x:Static lang:Resources.Auth_BrandCoffee}" />
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="22"
                                            FontWeight="Normal"
                                            Text="{x:Static lang:Resources.Auth_BrandPeek}">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{DynamicResource PrimaryContainerColor}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="14"
                                        Foreground="#E8FFFFFF"
                                        LineHeight="20"
                                        Text="{x:Static lang:Resources.Auth_RegisterHeroTagline}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Panel>
                        </Panel>

                        <!--  Form  -->
                        <ScrollViewer
                            Grid.Column="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel
                                Margin="32,28,32,28"
                                MinWidth="320"
                                Spacing="18">
                                <Button
                                    Classes="Secondary"
                                    Command="{Binding GoBackCommand}"
                                    Content="{x:Static lang:Resources.Common_Back}"
                                    CornerRadius="9999"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />

                                <StackPanel
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="20"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{x:Static lang:Resources.Auth_BrandCoffee}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="20"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Text="{x:Static lang:Resources.Auth_BrandPeek}" />
                                </StackPanel>

                                <!--  Email step copy  -->
                                <StackPanel IsVisible="{Binding IsEmailStep}" Spacing="6">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="26"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{x:Static lang:Resources.Register_CheckEmailTitle}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="15"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LineHeight="22"
                                        Text="{x:Static lang:Resources.Register_CheckEmailSubtitle}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Details header  -->
                                <StackPanel IsVisible="{Binding IsDetailsStep}" Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="26"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceBrush}"
                                            Grid.Column="0"
                                            Text="{x:Static lang:Resources.RegisterPage_Title}"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{DynamicResource SurfaceContainerLowBrush}"
                                            BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="9999"
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Padding="10,6"
                                            VerticalAlignment="Center">
                                            <StackPanel
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                                <PathIcon
                                                    Data="{StaticResource EnvelopeIcon}"
                                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                    Height="16"
                                                    VerticalAlignment="Center"
                                                    Width="16" />
                                                <TextBlock
                                                    FontFamily="{StaticResource RFDewiExpanded}"
                                                    FontSize="12"
                                                    FontWeight="Normal"
                                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                                    Text="{Binding Email}"
                                                    VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="15"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LineHeight="22"
                                        Text="{x:Static lang:Resources.Register_CompleteSubtitle}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding GoToEmailStepCommand}"
                                        FontSize="13"
                                        Foreground="{DynamicResource AuthLinkBrush}"
                                        HorizontalAlignment="Left"
                                        Padding="0">
                                        <TextBlock Text="{x:Static lang:Resources.Auth_ChangeEmail}" />
                                    </Button>
                                </StackPanel>

                                <Border
                                    Background="{DynamicResource AuthErrorBackgroundBrush}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    IsVisible="{Binding HasError}"
                                    Padding="14">
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource AuthErrorForegroundBrush}"
                                        Text="{Binding ErrorMessage}"
                                        TextWrapping="Wrap" />
                                </Border>

                                <!--  Email step fields  -->
                                <StackPanel IsVisible="{Binding IsEmailStep}" Spacing="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            LetterSpacing="0.06"
                                            Text="{x:Static lang:Resources.Auth_LabelEmailCaps}" />
                                        <TextBox
                                            Classes="form-field"
                                            PlaceholderText="{x:Static lang:Resources.LoginPage_EmailPlaceholder}"
                                            Text="{Binding Email}">
                                            <TextBox.InnerLeftContent>
                                                <PathIcon
                                                    Data="{StaticResource EnvelopeIcon}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Height="20"
                                                    Margin="16,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Width="20" />
                                            </TextBox.InnerLeftContent>
                                        </TextBox>
                                    </StackPanel>

                                    <Button
                                        Command="{Binding CheckEmailCommand}"
                                        CornerRadius="9999"
                                        FontSize="16"
                                        FontWeight="Normal"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        MinHeight="52">
                                        <Panel>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding !CheckEmailCommand.IsRunning}"
                                                Orientation="Horizontal"
                                                Spacing="10"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="{x:Static lang:Resources.Register_Continue}" VerticalAlignment="Center" />
                                                <PathIcon
                                                    Data="{StaticResource ArrowRightIcon}"
                                                    Foreground="{DynamicResource OnPrimaryBrush}"
                                                    Height="18"
                                                    Width="18" />
                                            </StackPanel>
                                            <ProgressBar
                                                Height="3"
                                                IsIndeterminate="True"
                                                IsVisible="{Binding CheckEmailCommand.IsRunning}"
                                                VerticalAlignment="Center" />
                                        </Panel>
                                    </Button>

                                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,0">
                                        <Border
                                            Background="{DynamicResource OutlineVariantBrush}"
                                            Grid.Column="0"
                                            Height="1"
                                            Opacity="0.5"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            Grid.Column="1"
                                            LetterSpacing="0.08"
                                            Margin="12,0"
                                            Text="{x:Static lang:Resources.Auth_OrContinueWith}" />
                                        <Border
                                            Background="{DynamicResource OutlineVariantBrush}"
                                            Grid.Column="2"
                                            Height="1"
                                            Opacity="0.5"
                                            VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Button
                                            Classes="Secondary"
                                            Content="{x:Static lang:Resources.Auth_Google}"
                                            CornerRadius="9999"
                                            FontWeight="Normal"
                                            Grid.Column="0"
                                            IsEnabled="False"
                                            MinHeight="48"
                                            Opacity="0.65" />
                                        <Button
                                            Classes="Secondary"
                                            Content="{x:Static lang:Resources.Auth_Apple}"
                                            CornerRadius="9999"
                                            FontWeight="Normal"
                                            Grid.Column="1"
                                            IsEnabled="False"
                                            MinHeight="48"
                                            Opacity="0.65" />
                                    </Grid>
                                </StackPanel>

                                <!--  Details step fields  -->
                                <StackPanel IsVisible="{Binding IsDetailsStep}" Spacing="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            LetterSpacing="0.06"
                                            Text="{x:Static lang:Resources.Auth_LabelFullNameCaps}" />
                                        <TextBox
                                            Classes="form-field"
                                            PlaceholderText="{x:Static lang:Resources.RegisterPage_FullNamePlaceholder}"
                                            Text="{Binding UserName}">
                                            <TextBox.InnerLeftContent>
                                                <PathIcon
                                                    Data="{StaticResource PersonIcon}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Height="20"
                                                    Margin="16,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Width="20" />
                                            </TextBox.InnerLeftContent>
                                        </TextBox>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            LetterSpacing="0.06"
                                            Text="{x:Static lang:Resources.Auth_LabelPasswordCaps}" />
                                        <TextBox
                                            Classes="form-field"
                                            PasswordChar="*"
                                            PlaceholderText="{x:Static lang:Resources.LoginPage_PasswordPlaceholder}"
                                            Text="{Binding Password}">
                                            <TextBox.InnerLeftContent>
                                                <PathIcon
                                                    Data="{StaticResource LockClosedIcon}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Height="20"
                                                    Margin="16,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Width="20" />
                                            </TextBox.InnerLeftContent>
                                        </TextBox>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            LetterSpacing="0.06"
                                            Text="{x:Static lang:Resources.Auth_LabelConfirmCaps}" />
                                        <TextBox
                                            Classes="form-field"
                                            PasswordChar="*"
                                            PlaceholderText="{x:Static lang:Resources.RegisterPage_ConfirmPasswordPlaceholder}"
                                            Text="{Binding ConfirmPassword}">
                                            <TextBox.InnerLeftContent>
                                                <PathIcon
                                                    Data="{StaticResource LockClosedIcon}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Height="20"
                                                    Margin="16,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Width="20" />
                                            </TextBox.InnerLeftContent>
                                        </TextBox>
                                    </StackPanel>

                                    <CheckBox IsChecked="{Binding AgreeToPrivacy}">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="13"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            Text="{x:Static lang:Resources.Auth_PrivacyConsent}"
                                            TextWrapping="Wrap" />
                                    </CheckBox>

                                    <Button
                                        Command="{Binding RegisterCommand}"
                                        CornerRadius="9999"
                                        FontSize="16"
                                        FontWeight="Normal"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        IsEnabled="{Binding AgreeToPrivacy}"
                                        MinHeight="52">
                                        <Panel>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding !RegisterCommand.IsRunning}"
                                                Orientation="Horizontal"
                                                Spacing="10"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="{x:Static lang:Resources.RegisterPage_RegisterButton}" VerticalAlignment="Center" />
                                                <PathIcon
                                                    Data="{StaticResource ArrowRightIcon}"
                                                    Foreground="{DynamicResource OnPrimaryBrush}"
                                                    Height="18"
                                                    Width="18" />
                                            </StackPanel>
                                            <ProgressBar
                                                Height="3"
                                                IsIndeterminate="True"
                                                IsVisible="{Binding RegisterCommand.IsRunning}"
                                                VerticalAlignment="Center" />
                                        </Panel>
                                    </Button>
                                </StackPanel>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="13"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        Text="{x:Static lang:Resources.Auth_HasAccount}"
                                        VerticalAlignment="Center" />
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding GoToLoginCommand}"
                                        FontSize="13"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Padding="0"
                                        VerticalAlignment="Center">
                                        <TextBlock Text="{x:Static lang:Resources.Auth_SignInCaps}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>
        </ScrollViewer>

        <Border
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Grid.Row="1"
            Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock
                    FontFamily="{StaticResource RFDewiExpanded}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                    Grid.Column="0"
                    Text="{x:Static lang:Resources.Auth_FooterCrafted}"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                    <Button
                        Classes="Transparent"
                        Content="{x:Static lang:Resources.WelcomePage_Footer_Privacy}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        Padding="0" />
                    <Button
                        Classes="Transparent"
                        Content="{x:Static lang:Resources.WelcomePage_Footer_Terms}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        Padding="0" />
                    <Button
                        Classes="Transparent"
                        Content="{x:Static lang:Resources.Auth_CookieSettings}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        Padding="0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
