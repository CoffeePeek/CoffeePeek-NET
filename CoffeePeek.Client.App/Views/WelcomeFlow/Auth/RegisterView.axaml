<UserControl
    d:DesignHeight="700"
    d:DesignWidth="480"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.WelcomeFlow.Auth.RegisterView"
    x:DataType="auth:RegisterViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:auth="clr-namespace:CoffeePeek.Client.App.ViewModels.WelcomeFlow.Auth"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:CoffeePeek.Client.App.Resources.Lang"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Border
            Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="{StaticResource DefaultCornerRadius}"
            HorizontalAlignment="Stretch"
            MaxWidth="480"
            Padding="{StaticResource DefaultPadding}"
            VerticalAlignment="Center">
            <StackPanel Spacing="16">
                <Button
                    Classes="Secondary"
                    Command="{Binding GoBackCommand}"
                    Content="{x:Static lang:Resources.Common_Back}"
                    HorizontalAlignment="Left" />
                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="{x:Static lang:Resources.RegisterPage_Title}" />
                <TextBox
                    PlaceholderText="{x:Static lang:Resources.RegisterPage_UserNamePlaceholder}"
                    Text="{Binding UserName}"
                    UseFloatingPlaceholder="True" />
                <TextBox
                    IsReadOnly="True"
                    PlaceholderText="{x:Static lang:Resources.LoginPage_EmailPlaceholder}"
                    Text="{Binding Email}"
                    UseFloatingPlaceholder="True" />
                <TextBox
                    PasswordChar="*"
                    PlaceholderText="{x:Static lang:Resources.LoginPage_PasswordPlaceholder}"
                    Text="{Binding Password}"
                    UseFloatingPlaceholder="True" />
                <TextBox
                    PasswordChar="*"
                    PlaceholderText="{x:Static lang:Resources.RegisterPage_ConfirmPasswordPlaceholder}"
                    Text="{Binding ConfirmPassword}"
                    UseFloatingPlaceholder="True" />
                <TextBlock
                    Foreground="{DynamicResource SystemAccentColor}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
                <Button
                    Command="{Binding RegisterCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center">
                    <Button.Content>
                        <StackPanel>
                            <TextBlock
                                HorizontalAlignment="Center"
                                IsVisible="{Binding !RegisterCommand.IsRunning}"
                                Text="{x:Static lang:Resources.RegisterPage_RegisterButton}" />
                            <ProgressBar
                                Height="4"
                                IsIndeterminate="True"
                                IsVisible="{Binding RegisterCommand.IsRunning}" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
