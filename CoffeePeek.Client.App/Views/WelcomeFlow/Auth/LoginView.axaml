<UserControl
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.WelcomeFlow.Auth.LoginView"
    x:DataType="auth:LoginViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:loc="clr-namespace:CoffeePeek.Client.App.Services"
    xmlns:auth="clr-namespace:CoffeePeek.Client.App.ViewModels.WelcomeFlow.Auth"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            Background="{DynamicResource SurfaceLowestBrush}"
            BorderThickness="0"
            Command="{Binding ToggleThemeCommand}"
            CornerRadius="{StaticResource PillRadius}"
            Grid.Row="0"
            HorizontalAlignment="Right"
            Margin="0,16,16,0"
            Padding="12"
            ToolTip.Tip="{Binding [Auth_ThemeToggle], Source={x:Static loc:Loc.Instance}}"
            VerticalAlignment="Top"
            ZIndex="30">
            <Panel Height="22" Width="22">
                <PathIcon
                    Data="{StaticResource ThemeMoonIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding ThemeShowsSunIcon}"
                    Width="22" />
                <PathIcon
                    Data="{StaticResource ThemeSunIcon}"
                    Foreground="{DynamicResource OnSurfaceBrush}"
                    Height="22"
                    IsVisible="{Binding !ThemeShowsSunIcon}"
                    Width="22" />
            </Panel>
        </Button>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            ZIndex="5">
            <Border
                Background="Transparent"
                HorizontalAlignment="Center"
                Margin="24,56,24,32"
                MaxWidth="960"
                MinWidth="320"
                Padding="0"
                VerticalAlignment="Center">
                <Border
                    Background="{DynamicResource SurfaceLowestBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="{StaticResource LargeRadius}">
                    <Grid ColumnDefinitions="*,*" MinHeight="520">
                        <!--  Hero  -->
                        <Panel Grid.Column="0" MinWidth="280">
                            <Image
                                HorizontalAlignment="Center"
                                Source="avares://CoffeePeek.Client.App/Assets/Auth/login-hero.jpg"
                                Stretch="UniformToFill"
                                VerticalAlignment="Center" />
                            <Rectangle IsHitTestVisible="False" VerticalAlignment="Stretch">
                                <Rectangle.Fill>
                                    <LinearGradientBrush EndPoint="50%,100%" StartPoint="50%,0%">
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#55000000" Offset="0.45" />
                                        <GradientStop Color="#99000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <StackPanel
                                Margin="28,0,28,32"
                                Spacing="12"
                                VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border
                                        CornerRadius="2"
                                        Height="18"
                                        VerticalAlignment="Center"
                                        Width="3">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource PrimaryContainerColor}" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="13"
                                        FontWeight="Normal"
                                        Text="{Binding [Auth_HeroTagSaffron], Source={x:Static loc:Loc.Instance}}">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{DynamicResource PrimaryContainerColor}" />
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="26"
                                    FontWeight="Normal"
                                    Foreground="White"
                                    LineHeight="32"
                                    Text="{Binding [Auth_LoginHeroHeadline], Source={x:Static loc:Loc.Instance}}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    FontFamily="{StaticResource RFDewiExpanded}"
                                    FontSize="14"
                                    Foreground="#E8FFFFFF"
                                    LineHeight="20"
                                    Text="{Binding [Auth_LoginHeroSub], Source={x:Static loc:Loc.Instance}}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Panel>

                        <!--  Form  -->
                        <ScrollViewer
                            Grid.Column="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel
                                Margin="32,28,32,28"
                                MinWidth="320"
                                Spacing="18">
                                <Button
                                    Classes="Secondary"
                                    Command="{Binding GoBackCommand}"
                                    Content="{Binding [Common_Back], Source={x:Static loc:Loc.Instance}}"
                                    CornerRadius="{StaticResource PillRadius}"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />

                                <StackPanel
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="20"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{Binding [Auth_BrandCoffee], Source={x:Static loc:Loc.Instance}}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="20"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Text="{Binding [Auth_BrandPeek], Source={x:Static loc:Loc.Instance}}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="26"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{Binding [LoginPage_Title], Source={x:Static loc:Loc.Instance}}" />
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="15"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LineHeight="22"
                                        Text="{Binding [LoginPage_Subtitle], Source={x:Static loc:Loc.Instance}}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Border
                                    Background="{DynamicResource AuthErrorBackgroundBrush}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    IsVisible="{Binding HasError}"
                                    Padding="14">
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource AuthErrorForegroundBrush}"
                                        Text="{Binding ErrorMessage}"
                                        TextWrapping="Wrap" />
                                </Border>

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="11"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        LetterSpacing="0.06"
                                        Text="{Binding [Auth_LabelEmailCaps], Source={x:Static loc:Loc.Instance}}" />
                                    <TextBox
                                        Classes="form-field"
                                        PlaceholderText="{Binding [LoginPage_EmailPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        Text="{Binding Email}">
                                        <TextBox.InnerLeftContent>
                                            <PathIcon
                                                Data="{StaticResource EnvelopeIcon}"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Height="20"
                                                Margin="16,0,8,0"
                                                VerticalAlignment="Center"
                                                Width="20" />
                                        </TextBox.InnerLeftContent>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock
                                            FontFamily="{StaticResource RFDewiExpanded}"
                                            FontSize="11"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                            Grid.Column="0"
                                            LetterSpacing="0.06"
                                            Text="{Binding [Auth_LabelPasswordCaps], Source={x:Static loc:Loc.Instance}}"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Classes="Transparent"
                                            Command="{Binding ForgotPasswordCommand}"
                                            Content="{Binding [Auth_ForgotPassword], Source={x:Static loc:Loc.Instance}}"
                                            FontSize="12"
                                            FontWeight="Normal"
                                            Grid.Column="1"
                                            Padding="0"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBox
                                        Classes="form-field"
                                        PasswordChar="*"
                                        PlaceholderText="{Binding [LoginPage_PasswordPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        Text="{Binding Password}">
                                        <TextBox.InnerLeftContent>
                                            <PathIcon
                                                Data="{StaticResource LockClosedIcon}"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Height="20"
                                                Margin="16,0,8,0"
                                                VerticalAlignment="Center"
                                                Width="20" />
                                        </TextBox.InnerLeftContent>
                                    </TextBox>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding RememberThisMachine}">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="13"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        Text="{Binding [Auth_RememberMachine], Source={x:Static loc:Loc.Instance}}" />
                                </CheckBox>

                                <Button
                                    Command="{Binding LoginCommand}"
                                    CornerRadius="{StaticResource PillRadius}"
                                    FontSize="16"
                                    FontWeight="Normal"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    IsEnabled="{Binding !LoginCommand.IsRunning}"
                                    MinHeight="52">
                                    <Panel>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            IsVisible="{Binding !LoginCommand.IsRunning}"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            VerticalAlignment="Center">
                                            <TextBlock Text="{Binding [LoginPage_LoginButton], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" />
                                            <PathIcon
                                                Data="{StaticResource ArrowRightIcon}"
                                                Foreground="{DynamicResource OnPrimaryBrush}"
                                                Height="18"
                                                Width="18" />
                                        </StackPanel>
                                        <ProgressBar
                                            Height="3"
                                            IsIndeterminate="True"
                                            IsVisible="{Binding LoginCommand.IsRunning}"
                                            VerticalAlignment="Center" />
                                    </Panel>
                                </Button>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <TextBlock
                                        FontFamily="{StaticResource RFDewiExpanded}"
                                        FontSize="13"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        Text="{Binding [Auth_NoAccount], Source={x:Static loc:Loc.Instance}}"
                                        VerticalAlignment="Center" />
                                    <Button
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding GoToRegisterCommand}"
                                        FontSize="13"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Padding="0"
                                        VerticalAlignment="Center">
                                        <TextBlock Text="{Binding [Auth_RequestAccess], Source={x:Static loc:Loc.Instance}}" />
                                    </Button>
                                </StackPanel>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Border
                                        Background="{DynamicResource PrimaryBrush}"
                                        CornerRadius="2"
                                        Height="4"
                                        Width="40" />
                                    <Border
                                        Background="{DynamicResource OutlineVariantBrush}"
                                        CornerRadius="2"
                                        Height="4"
                                        Opacity="0.5"
                                        Width="40" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>
        </ScrollViewer>

        <Border
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Grid.Row="1"
            Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock
                    FontFamily="{StaticResource RFDewiExpanded}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                    Grid.Column="0"
                    Text="{Binding [Auth_FooterCrafted], Source={x:Static loc:Loc.Instance}}"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                    <Button
                        Classes="Transparent"
                        Content="{Binding [WelcomePage_Footer_Privacy], Source={x:Static loc:Loc.Instance}}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        IsEnabled="False"
                        Padding="0" />
                    <Button
                        Classes="Transparent"
                        Content="{Binding [WelcomePage_Footer_Terms], Source={x:Static loc:Loc.Instance}}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        IsEnabled="False"
                        Padding="0" />
                    <Button
                        Classes="Transparent"
                        Content="{Binding [Auth_CookieSettings], Source={x:Static loc:Loc.Instance}}"
                        FontFamily="{StaticResource RFDewiExpanded}"
                        FontSize="12"
                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                        IsEnabled="False"
                        Padding="0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
