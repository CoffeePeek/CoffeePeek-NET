<UserControl
    d:DesignHeight="400"
    d:DesignWidth="720"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Home.PlaceholderPageView"
    x:DataType="home:PlaceholderPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:home="clr-namespace:CoffeePeek.Client.App.ViewModels.Home"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Margin="24"
        Padding="40,48"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        MaxWidth="560"
        Background="{DynamicResource SurfaceContainerLowBrush}"
        CornerRadius="{StaticResource LargeRadius}">
        <StackPanel Spacing="16">
            <TextBlock
                Classes="Headline"
                FontSize="24"
                FontWeight="Normal"
                Foreground="{DynamicResource OnSurfaceBrush}"
                Text="{Binding Title}"
                TextWrapping="Wrap" />
            <TextBlock
                FontSize="15"
                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                LineHeight="22"
                Text="{Binding Message}"
                TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
