<UserControl
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Home.UserProfileView"
    x:DataType="home:UserProfileViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:ac="using:Avalonia.Data.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:home="clr-namespace:CoffeePeek.Client.App.ViewModels.Home"
    xmlns:lang="clr-namespace:CoffeePeek.Client.App.Resources.Lang"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource SurfaceBrush}" RowDefinitions="Auto,*">
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Right"
            Margin="16,12,16,8"
            Orientation="Horizontal"
            Spacing="12"
            ZIndex="2">
            <Button
                Classes="Secondary"
                Command="{Binding ToggleThemeCommand}"
                Content="{x:Static lang:Resources.Profile_ThemeToggle}" />
            <Button Command="{Binding SignOutCommand}" Content="{x:Static lang:Resources.Profile_Logout}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <!-- Loading -->
            <Border
                Background="{DynamicResource SurfaceBrush}"
                IsVisible="{Binding IsLoadingProfile}"
                MinHeight="360">
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="12"
                    VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="{x:Static lang:Resources.Profile_Loading}" />
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border
                Background="{DynamicResource SurfaceBrush}"
                IsVisible="{Binding ErrorMessage, Converter={x:Static ac:StringConverters.IsNotNullOrEmpty}}"
                MinHeight="360"
                Padding="24">
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="16"
                    VerticalAlignment="Center">
                    <TextBlock
                        Classes="Headline"
                        HorizontalAlignment="Center"
                        Text="{Binding ErrorMessage}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Profile body -->
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                IsVisible="{Binding ShowProfileBody}">
                <StackPanel Spacing="0">
                    <Border
                        Background="{DynamicResource SurfaceContainerLowBrush}"
                        BorderThickness="0"
                        Padding="48,40">
                        <StackPanel
                            MaxWidth="960"
                            HorizontalAlignment="Stretch"
                            Orientation="Horizontal"
                            Spacing="32">
                            <Border
                                BorderThickness="0"
                                ClipToBounds="True"
                                CornerRadius="64"
                                Height="128"
                                Width="128">
                                <Panel>
                                    <Image
                                        IsVisible="{Binding HasAvatar}"
                                        Source="{Binding AvatarImage}"
                                        Stretch="UniformToFill" />
                                    <Border
                                        Background="{DynamicResource PrimaryGradientBrush}"
                                        IsVisible="{Binding !HasAvatar}">
                                        <TextBlock
                                            FontSize="48"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource OnPrimaryBrush}"
                                            HorizontalAlignment="Center"
                                            Text="{Binding InitialLetter}"
                                            VerticalAlignment="Center" />
                                    </Border>
                                </Panel>
                            </Border>

                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                <TextBlock
                                    Classes="Headline"
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Text="{Binding UserName}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    IsVisible="{Binding HasMemberSince}"
                                    Text="{Binding MemberSinceLabel}" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    IsVisible="{Binding About, Converter={x:Static ac:StringConverters.IsNotNullOrEmpty}}"
                                    MaxWidth="480"
                                    Text="{Binding About}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="48,32" MaxWidth="960" Spacing="32">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                            <Border
                                Background="{DynamicResource SurfaceContainerLowBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Padding="24">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        Text="{Binding CheckInCount}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        HorizontalAlignment="Center"
                                        Text="{x:Static lang:Resources.Profile_StatCheckIns}" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Background="{DynamicResource SurfaceContainerLowBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Padding="24">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        Text="{Binding ReviewCount}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        HorizontalAlignment="Center"
                                        Text="{x:Static lang:Resources.Profile_StatReviews}" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="2"
                                Background="{DynamicResource SurfaceContainerLowBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Padding="24">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        Text="{Binding AverageRatingLabel}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        HorizontalAlignment="Center"
                                        Text="{x:Static lang:Resources.Profile_StatRating}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Spacing="12">
                            <TextBlock
                                Classes="Headline"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{x:Static lang:Resources.Profile_LastReviews}" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                Text="{Binding ReviewsSubtitle}" />

                            <Panel MinHeight="120">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsLoadingReviews}"
                                    VerticalAlignment="Center">
                                    <ProgressBar
                                        HorizontalAlignment="Center"
                                        IsIndeterminate="True"
                                        Width="160" />
                                </StackPanel>

                                <ItemsControl IsVisible="{Binding HasReviews}" ItemsSource="{Binding Reviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="home:UserProfileReviewRowViewModel">
                                            <Border
                                                Background="{DynamicResource SurfaceContainerLowBrush}"
                                                BorderThickness="0"
                                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                                Margin="0,0,0,16"
                                                Padding="20">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock
                                                            FontWeight="Bold"
                                                            Text="{Binding Title}"
                                                            TextWrapping="Wrap" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                            Text="{Binding FormattedDate}" />
                                                    </Grid>
                                                    <TextBlock
                                                        FontSize="13"
                                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                        IsVisible="{Binding Comment, Converter={x:Static ac:StringConverters.IsNotNullOrEmpty}}"
                                                        Text="{Binding Comment}"
                                                        TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock
                                                            FontSize="14"
                                                            Foreground="{DynamicResource PrimaryBrush}"
                                                            Text="{Binding StarsText}" />
                                                        <Button
                                                            Classes="Transparent"
                                                            Command="{Binding GoToShopCommand}"
                                                            Content="{x:Static lang:Resources.Profile_GoToShop}"
                                                            Padding="4,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border
                                    Background="{DynamicResource SurfaceContainerLowBrush}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    IsVisible="{Binding ShowReviewsEmpty}"
                                    Padding="32">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        Text="{x:Static lang:Resources.Profile_NoReviews}"
                                        TextAlignment="Center" />
                                </Border>
                            </Panel>

                            <StackPanel
                                HorizontalAlignment="Center"
                                IsVisible="{Binding ShowReviewPagination}"
                                Orientation="Horizontal"
                                Spacing="16">
                                <Button
                                    Classes="Secondary"
                                    Command="{Binding ReviewPrevCommand}"
                                    Content="{x:Static lang:Resources.Profile_PreviousPage}"
                                    IsEnabled="{Binding CanReviewPrev}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{Binding PaginationSummary}" />
                                <Button
                                    Classes="Secondary"
                                    Command="{Binding ReviewNextCommand}"
                                    Content="{x:Static lang:Resources.Profile_NextPage}"
                                    IsEnabled="{Binding CanReviewNext}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
