<UserControl
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Shops.Catalog.ShopsCatalogSearchRowView"
    x:DataType="shops:ShopsPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lang="clr-namespace:CoffeePeek.Client.App.Resources.Lang"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shops="clr-namespace:CoffeePeek.Client.App.ViewModels.Shops"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        ColumnDefinitions="*,Auto"
        ColumnSpacing="12"
        Margin="20,20,20,0">
        <TextBox
            Grid.Column="0"
            MinHeight="56"
            PlaceholderText="{x:Static lang:Resources.ShopPage_SearchPlaceholder}"
            Text="{Binding SearchQuery}"
            VerticalContentAlignment="Center">
            <TextBox.InnerLeftContent>
                <PathIcon
                    Data="{StaticResource SearchIcon}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center" />
            </TextBox.InnerLeftContent>
            <TextBox.InnerRightContent>
                <Button
                    Command="{Binding ToggleAdditionalFiltersCommand}"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Margin="0,6,6,6"
                    Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon
                            Data="{StaticResource FiltersIcon}"
                            Foreground="{DynamicResource OnPrimaryBrush}"
                            VerticalAlignment="Center" />
                        <TextBlock
                            FontSize="14"
                            Foreground="{DynamicResource OnPrimaryBrush}"
                            Text="{x:Static lang:Resources.ShopPage_Filter}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </TextBox.InnerRightContent>
        </TextBox>

        <Button
            Classes="Secondary"
            Command="{Binding OpenSuggestShopCommand}"
            Content="{x:Static lang:Resources.ShopPage_SuggestShop}"
            Grid.Column="1"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
