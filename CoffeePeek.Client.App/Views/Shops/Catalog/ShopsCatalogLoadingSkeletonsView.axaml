<UserControl
    d:DesignHeight="360"
    d:DesignWidth="960"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Shops.Catalog.ShopsCatalogLoadingSkeletonsView"
    x:DataType="shops:ShopsPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:catalog="clr-namespace:CoffeePeek.Client.App.Views.Shops.Catalog"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shops="clr-namespace:CoffeePeek.Client.App.ViewModels.Shops"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <WrapPanel HorizontalAlignment="Center" IsVisible="{Binding IsLoading}" Orientation="Horizontal">
        <catalog:ShopCardSkeletonItemView />
        <catalog:ShopCardSkeletonItemView />
        <catalog:ShopCardSkeletonItemView />
    </WrapPanel>
</UserControl>
