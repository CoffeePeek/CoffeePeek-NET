<UserControl
    d:DesignHeight="64"
    d:DesignWidth="64"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Shops.Catalog.ShopsCatalogMapFab"
    x:DataType="shops:ShopsPageViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shops="clr-namespace:CoffeePeek.Client.App.ViewModels.Shops"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Panel IsHitTestVisible="False" ZIndex="20">
        <Button
            Background="{DynamicResource AuthLinkBrush}"
            Command="{Binding BrowseMapCommand}"
            CornerRadius="32"
            Height="56"
            HorizontalAlignment="Right"
            IsHitTestVisible="True"
            Margin="0,0,28,28"
            Padding="0"
            VerticalAlignment="Bottom"
            Width="56">
        <PathIcon
            Data="{StaticResource MapIcon}"
            Foreground="{DynamicResource OnSurfaceBrush}"
            Height="26"
            Width="26" />
        </Button>
    </Panel>
</UserControl>
