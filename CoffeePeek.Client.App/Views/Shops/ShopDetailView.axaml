<UserControl
    d:DesignHeight="960"
    d:DesignWidth="1200"
    mc:Ignorable="d"
    x:Class="CoffeePeek.Client.App.Views.Shops.ShopDetailView"
    x:DataType="shops:ShopDetailViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:loc="clr-namespace:CoffeePeek.Client.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shops="clr-namespace:CoffeePeek.Client.App.ViewModels.Shops"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <Border
            Grid.Row="0"
            Background="{DynamicResource SurfaceContainerLowBrush}"
            Padding="16,10">
            <Button
                Classes="Transparent"
                Command="{Binding GoBackCommand}"
                HorizontalAlignment="Left"
                Padding="8,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16" Text="←" VerticalAlignment="Center" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{DynamicResource OnSurfaceBrush}"
                        Text="{Binding [Common_Back], Source={x:Static loc:Loc.Instance}}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                IsVisible="{Binding IsLoading}">
                <Grid
                    ColumnDefinitions="*,310"
                    ColumnSpacing="24"
                    HorizontalAlignment="Center"
                    Margin="24,0,24,32"
                    MaxWidth="1200"
                    MinWidth="520"
                    RowDefinitions="Auto,Auto,*">
                    <Border
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Classes="shimmer shop-detail-hero"
                        CornerRadius="0,0,32,32"
                        Height="300" />
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,20,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Border Classes="shimmer-line" CornerRadius="8" Height="40" Width="120" />
                        <Border Classes="shimmer-line" CornerRadius="8" Height="40" Width="160" />
                        <Border Classes="shimmer-line" CornerRadius="8" Height="40" Width="100" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,24,0,0"
                        Spacing="16">
                        <Border Classes="shimmer-line" Height="22" HorizontalAlignment="Left" Width="200" />
                        <Border Classes="shimmer-line" Height="14" Width="320" />
                        <Border Classes="shimmer-line" Height="14" Width="280" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="shimmer-line" CornerRadius="8" Height="28" Width="72" />
                            <Border Classes="shimmer-line" CornerRadius="8" Height="28" Width="88" />
                            <Border Classes="shimmer-line" CornerRadius="8" Height="28" Width="64" />
                        </StackPanel>
                        <Border Classes="shimmer-line" Height="160" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="1"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Margin="0,20,0,0"
                        Spacing="16">
                        <Border Classes="shimmer" CornerRadius="16" Height="220" />
                        <Border Classes="shimmer" CornerRadius="16" Height="148" />
                        <Border Classes="shimmer" CornerRadius="16" Height="100" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border
                Background="{DynamicResource AuthErrorBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                HorizontalAlignment="Center"
                IsVisible="{Binding HasError}"
                Margin="24"
                Padding="16,12"
                VerticalAlignment="Top">
                <TextBlock
                    FontSize="14"
                    Foreground="{DynamicResource AuthErrorForegroundBrush}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding !IsLoading}">
                <Grid
                    ColumnDefinitions="*,310"
                    ColumnSpacing="24"
                    HorizontalAlignment="Center"
                    Margin="24,0,24,32"
                    MaxWidth="1200"
                    MinWidth="520"
                    RowDefinitions="Auto,Auto,*">
                    <!-- Hero -->
                    <Border
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Classes="shop-detail-hero">
                        <Panel>
                            <Border Background="{DynamicResource CardToneGradientBrush}" />
                            <Image
                                IsVisible="{Binding HasHeroImage}"
                                Source="{Binding CoverBitmap}"
                                Stretch="UniformToFill" />
                            <Border
                                HorizontalAlignment="Stretch"
                                IsHitTestVisible="False"
                                VerticalAlignment="Stretch">
                                <Border.Background>
                                    <LinearGradientBrush EndPoint="50%,100%" StartPoint="50%,0%">
                                        <GradientStop Offset="0" Color="#00000000" />
                                        <GradientStop Offset="1" Color="#99000000" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border
                                HorizontalAlignment="Right"
                                Margin="16,16,16,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource SurfaceContainerHighBrush}"
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Opacity="0.95"
                                Padding="12,6">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Text="{Binding PriceLabel}" />
                            </Border>
                            <StackPanel
                                Margin="20,0,20,20"
                                Spacing="10"
                                VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border
                                        Background="{DynamicResource SurfaceContainerHighBrush}"
                                        CornerRadius="{StaticResource DefaultCornerRadius}"
                                        IsVisible="{Binding IsOpen}"
                                        Opacity="0.95"
                                        Padding="10,5">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Text="{Binding [ShopDetail_Open], Source={x:Static loc:Loc.Instance}}" />
                                    </Border>
                                    <Border
                                        Background="{DynamicResource PrimaryGradientBrush}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        IsVisible="{Binding IsNew}"
                                        Padding="10,5">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="Normal"
                                            Foreground="{DynamicResource OnPrimaryBrush}"
                                            Text="{Binding [ShopPage_Trending], Source={x:Static loc:Loc.Instance}}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="Black"
                                    Foreground="#FFFFFF"
                                    Text="{Binding Name}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Panel>
                    </Border>

                    <!-- Quick info -->
                    <Grid
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        ColumnDefinitions="*,*,*"
                        Margin="0,20,0,0">
                        <Border Classes="shop-detail-quick-info" Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="shop-detail-quick-icon" Data="{StaticResource StarIcon}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    Text="{Binding RatingSummary}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Classes="shop-detail-quick-info" Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="shop-detail-quick-icon" Data="{StaticResource MapPinIcon}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    Text="{Binding QuickAddressLine}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Classes="shop-detail-quick-info" Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Classes="shop-detail-quick-icon" Data="{StaticResource ClockIcon}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    Text="{Binding OpenUntilText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Main column -->
                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="0"
                        IsVisible="{Binding IsDetailContentVisible}"
                        Margin="0,24,0,0"
                        Spacing="24">
                        <StackPanel IsVisible="{Binding HasDescription}" Spacing="8">
                            <TextBlock
                                Classes="Headline"
                                FontSize="20"
                                FontWeight="Black"
                                Text="{Binding [ShopDetail_About], Source={x:Static loc:Loc.Instance}}" />
                            <TextBlock
                                FontSize="14"
                                FontWeight="Normal"
                                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                LineHeight="22"
                                Text="{Binding Description}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Classes="Secondary"
                                Command="{Binding ShareShopCommand}"
                                FontWeight="Black"
                                IsVisible="{Binding CanShare}"
                                Padding="20,10"
                                Content="{Binding [ShopDetail_Share], Source={x:Static loc:Loc.Instance}}" />
                            <Button
                                Command="{Binding OrderOrCallCommand}"
                                FontWeight="Black"
                                IsVisible="{Binding CanOrder}"
                                Padding="20,10"
                                Content="{Binding [ShopDetail_Order], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="shop-detail-chip">
                                        <TextBlock Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding HasContact}" Spacing="10">
                            <TextBlock
                                FontSize="14"
                                FontWeight="Black"
                                Foreground="{DynamicResource OnSurfaceBrush}"
                                Text="{Binding [ShopDetail_Contact], Source={x:Static loc:Loc.Instance}}" />
                            <StackPanel
                                IsVisible="{Binding Phone, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Orientation="Horizontal"
                                Spacing="8">
                                <PathIcon
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource PhoneIcon}"
                                    Foreground="{DynamicResource PrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    Text="{Binding Phone}" />
                            </StackPanel>
                            <StackPanel
                                IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Orientation="Horizontal"
                                Spacing="8">
                                <PathIcon
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource EnvelopeIcon}"
                                    Foreground="{DynamicResource PrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                    Text="{Binding Email}" />
                            </StackPanel>
                            <StackPanel
                                IsVisible="{Binding Website, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Orientation="Horizontal"
                                Spacing="8">
                                <PathIcon
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource GlobeIcon}"
                                    Foreground="{DynamicResource PrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Text="{Binding Website}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel
                                IsVisible="{Binding Instagram, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Orientation="Horizontal"
                                Spacing="8">
                                <PathIcon
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource InstagramIcon}"
                                    Foreground="{DynamicResource PrimaryBrush}" />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Text="{Binding Instagram}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Reviews card -->
                        <Border Classes="shop-detail-reviews-card">
                            <StackPanel Spacing="16">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="Black"
                                    Foreground="{DynamicResource OnSurfaceBrush}"
                                    Text="{Binding [ShopDetail_Reviews], Source={x:Static loc:Loc.Instance}}" />

                                <!-- Submit new review form -->
                                <Border
                                    Background="{DynamicResource SurfaceContainerLowBrush}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource DefaultCornerRadius}"
                                    IsVisible="{Binding CanCreateReview}"
                                    Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{Binding [ShopDetail_AddReview], Source={x:Static loc:Loc.Instance}}" />
                                        <TextBox
                                            AcceptsReturn="True"
                                            MinHeight="84"
                                            PlaceholderText="{Binding [ShopDetail_ReviewCommentPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                            Text="{Binding NewReviewComment}"
                                            TextWrapping="Wrap" />
                                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock FontSize="12" Text="{Binding [ShopDetail_RatingPlace], Source={x:Static loc:Loc.Instance}}" />
                                                <ComboBox
                                                    ItemsSource="{Binding ScoreOptions}"
                                                    SelectedItem="{Binding PlaceScore}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock FontSize="12" Text="{Binding [ShopDetail_RatingService], Source={x:Static loc:Loc.Instance}}" />
                                                <ComboBox
                                                    ItemsSource="{Binding ScoreOptions}"
                                                    SelectedItem="{Binding ServiceScore}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <TextBlock FontSize="12" Text="{Binding [ShopDetail_RatingCoffee], Source={x:Static loc:Loc.Instance}}" />
                                                <ComboBox
                                                    ItemsSource="{Binding ScoreOptions}"
                                                    SelectedItem="{Binding CoffeeScore}" />
                                            </StackPanel>
                                        </Grid>
                                        <Button
                                            Classes="Primary"
                                            Command="{Binding SubmitReviewCommand}"
                                            Content="{Binding [ShopDetail_SubmitReview], Source={x:Static loc:Loc.Instance}}"
                                            HorizontalAlignment="Left"
                                            IsEnabled="{Binding !IsSubmittingReview}"
                                            Padding="14,8" />
                                    </StackPanel>
                                </Border>

                                <!-- Review error -->
                                <Border
                                    Background="{DynamicResource AuthErrorBackgroundBrush}"
                                    IsVisible="{Binding HasReviewError}"
                                    Padding="12,8">
                                    <TextBlock
                                        Foreground="{DynamicResource AuthErrorForegroundBrush}"
                                        Text="{Binding ReviewErrorMessage}" />
                                </Border>

                                <!-- Empty state -->
                                <StackPanel IsVisible="{Binding !HasReviewItems}" Spacing="12">
                                    <PathIcon
                                        Width="40"
                                        Height="40"
                                        HorizontalAlignment="Left"
                                        Data="{StaticResource ChatBubbleIcon}"
                                        Foreground="{DynamicResource PrimaryBrush}" />
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Black"
                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                        Text="{Binding [ShopDetail_ReviewsEmptyTitle], Source={x:Static loc:Loc.Instance}}" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                        Text="{Binding [ShopDetail_ReviewsEmptySubtitle], Source={x:Static loc:Loc.Instance}}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Command="{Binding WriteReviewCommand}"
                                        Content="{Binding [ShopDetail_WriteReview], Source={x:Static loc:Loc.Instance}}"
                                        FontWeight="Black"
                                        HorizontalAlignment="Left"
                                        Padding="20,10" />
                                </StackPanel>

                                <!-- Review list -->
                                <ItemsControl IsVisible="{Binding HasReviewItems}" ItemsSource="{Binding Reviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="shops:ShopReviewViewModel">
                                            <Border
                                                Background="{DynamicResource SurfaceContainerBrush}"
                                                BorderThickness="0"
                                                CornerRadius="{StaticResource SmallCornerRadius}"
                                                Margin="0,0,0,12"
                                                Padding="16">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock
                                                                FontSize="14"
                                                                FontWeight="Normal"
                                                                Foreground="{DynamicResource OnSurfaceBrush}"
                                                                Text="{Binding Username}" />
                                                            <TextBlock
                                                                FontSize="13"
                                                                FontWeight="Normal"
                                                                Foreground="{DynamicResource PrimaryBrush}"
                                                                Text="{Binding StarsText}"
                                                                VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                            <TextBlock
                                                                FontSize="11"
                                                                FontWeight="Normal"
                                                                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                                Text="{Binding DateLabel}"
                                                                VerticalAlignment="Center" />
                                                            <Button
                                                                Classes="Secondary"
                                                                Command="{Binding $parent[UserControl].((shops:ShopDetailViewModel)DataContext).DeleteReviewCommand}"
                                                                CommandParameter="{Binding .}"
                                                                Content="{Binding [ShopDetail_DeleteReview], Source={x:Static loc:Loc.Instance}}"
                                                                IsEnabled="{Binding !$parent[UserControl].((shops:ShopDetailViewModel)DataContext).IsDeletingReview}"
                                                                IsVisible="{Binding IsOwnReview}"
                                                                Padding="10,3" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock
                                                        FontSize="14"
                                                        FontWeight="Normal"
                                                        Foreground="{DynamicResource OnSurfaceBrush}"
                                                        Text="{Binding Header}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="Normal"
                                                        Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                        IsVisible="{Binding HasComment}"
                                                        Text="{Binding Comment}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Sidebar -->
                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="0,24,0,0"
                        Spacing="16">
                        <Border
                            Classes="shop-detail-sidebar-card"
                            IsVisible="{Binding HasSchedule}">
                            <StackPanel Spacing="14">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Black"
                                    Foreground="{DynamicResource ShopDetailSidebarAccentBrush}"
                                    Text="{Binding [ShopDetail_Hours], Source={x:Static loc:Loc.Instance}}" />
                                <StackPanel IsVisible="{Binding IsOpen}" Orientation="Horizontal" Spacing="8">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource ShopDetailOpenDotBrush}" />
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="Normal"
                                        Foreground="{DynamicResource ShopDetailSidebarOnDarkBrush}"
                                        Text="{Binding [ShopDetail_OpenNow], Source={x:Static loc:Loc.Instance}}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Schedule}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="shops:ScheduleLineViewModel">
                                            <Grid Margin="0,0,0,4" ColumnDefinitions="56,*">
                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="Normal"
                                                    Foreground="{DynamicResource ShopDetailSidebarOnDarkBrush}"
                                                    Text="{Binding DayName}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="13"
                                                    FontWeight="Normal"
                                                    Foreground="{DynamicResource ShopDetailSidebarOnDarkBrush}"
                                                    Opacity="0.85"
                                                    Text="{Binding Hours}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border
                            Classes="shop-detail-sidebar-card"
                            IsVisible="{Binding HasMapCoordinates}"
                            Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Black"
                                    Foreground="{DynamicResource ShopDetailSidebarAccentBrush}"
                                    Text="{Binding [ShopDetail_MapArea], Source={x:Static loc:Loc.Instance}}" />
                                <Border Classes="shop-detail-map-stub">
                                    <Panel>
                                        <Border Background="{DynamicResource CardToneGradientBrush}" />
                                        <PathIcon
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Data="{StaticResource MapPinIcon}"
                                            Foreground="{DynamicResource PrimaryBrush}" />
                                    </Panel>
                                </Border>
                                <Button
                                    Classes="Secondary"
                                    Command="{Binding GetDirectionsCommand}"
                                    FontWeight="Black"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding CanGetDirections}"
                                    Padding="16,10"
                                    Content="{Binding [ShopDetail_GetDirections], Source={x:Static loc:Loc.Instance}}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="shop-detail-sidebar-card" IsVisible="{Binding HasAmenities}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Black"
                                    Foreground="{DynamicResource ShopDetailSidebarAccentBrush}"
                                    Text="{Binding [ShopDetail_Amenities], Source={x:Static loc:Loc.Instance}}" />
                                <ItemsControl ItemsSource="{Binding AmenityLabels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="4,0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon
                                                        Width="18"
                                                        Height="18"
                                                        VerticalAlignment="Top"
                                                        Data="{StaticResource CoffeeBrandIcon}"
                                                        Foreground="{DynamicResource ShopDetailSidebarOnDarkBrush}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="Normal"
                                                        Foreground="{DynamicResource ShopDetailSidebarOnDarkBrush}"
                                                        Text="{Binding}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
