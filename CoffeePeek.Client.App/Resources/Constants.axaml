<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 0.5rem (md) architectural radius; no box borders by default — use tonal surfaces. -->
    <Thickness x:Key="DefaultThickness">0.6</Thickness>

    <x:Double x:Key="DefaultBorder">1</x:Double>
    <x:Double x:Key="DefaultSpacing">8</x:Double>

    <Thickness x:Key="DefaultPadding">8</Thickness>

    <CornerRadius x:Key="SuperLargeRadius">18</CornerRadius>
    <CornerRadius x:Key="LargeRadius">12</CornerRadius>
    <CornerRadius x:Key="DefaultCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
</ResourceDictionary>
