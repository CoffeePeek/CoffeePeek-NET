<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Editorial “daylight” companion: warm paper surfaces, same Saffron accent (no pure white). -->

    <BoxShadows x:Key="ShadowAmbientFloat">0 20 40 0 #66000000</BoxShadows>

    <Color x:Key="PrimaryColor">#FFBA46</Color>
    <Color x:Key="PrimaryContainerColor">#CA8A04</Color>
    <Color x:Key="PrimaryHoverColor">#E8A82E</Color>
    <Color x:Key="OnPrimaryColor">#442C00</Color>

    <Color x:Key="SurfaceColor">#EDE6DD</Color>
    <Color x:Key="SurfaceContainerLowestColor">#E8E1D6</Color>
    <Color x:Key="SurfaceContainerLowColor">#E0D8CC</Color>
    <Color x:Key="SurfaceContainerColor">#D4CABA</Color>
    <Color x:Key="SurfaceContainerHighColor">#C9BDAF</Color>

    <Color x:Key="OnSurfaceColor">#2A241E</Color>
    <Color x:Key="OnSurfaceVariantColor">#5C534A</Color>

    <Color x:Key="OutlineColor">#9E8E7B</Color>
    <Color x:Key="OutlineVariantColor">#8A7B6C</Color>

    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="OnErrorSurfaceColor">#B91C1C</Color>

    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientHoverBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryHoverColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%" x:Key="CardToneGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource SurfaceContainerLowColor}" />
        <GradientStop Offset="1" Color="{StaticResource SurfaceContainerColor}" />
    </LinearGradientBrush>

    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryHoverColor}" x:Key="PrimaryHoverBrush" />
    <SolidColorBrush Color="{StaticResource OnPrimaryColor}" x:Key="OnPrimaryBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceColor}" x:Key="SurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="SurfaceLowestBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="SurfaceContainerLowBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="SurfaceContainerBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerHighColor}" x:Key="SurfaceContainerHighBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="SurfaceBrightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="OnSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="OnSurfaceVariantBrush" />

    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.18" x:Key="OutlineVariantGhostBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}" Opacity="0.25" x:Key="OutlineGhostBrush" />

    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="TextPrimaryBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.12" x:Key="BorderBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="SecondaryLightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="SecondaryBrush" />

    <SolidColorBrush Color="#44CA8A04" x:Key="PrimaryGoldTransparent" />
    <SolidColorBrush Color="#55CA8A04" x:Key="TextSelectionBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="TextSelectionForegroundBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="AppSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="AppSurfaceAltBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}" Opacity="0.25" x:Key="AppBorderColor" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.2" x:Key="AppBorderSubtleBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.15" x:Key="AppBorderBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="AuthPageBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="AuthCardBackgroundBrush" />
    <SolidColorBrush Color="Transparent" x:Key="AuthCardBorderBrush" />
    <SolidColorBrush Color="#19DC2626" x:Key="AuthErrorBackgroundBrush" />
    <SolidColorBrush Color="#33DC2626" x:Key="AuthErrorBorderBrush" />
    <SolidColorBrush Color="{StaticResource OnErrorSurfaceColor}" x:Key="AuthErrorForegroundBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryContainerColor}" x:Key="AuthLinkBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="AppBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="AppSurfaceColor" />
</ResourceDictionary>
