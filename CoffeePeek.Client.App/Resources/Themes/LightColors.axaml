<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        CoffeePeek light theme — canonical design-system values.
        Page:   #FAFAF9  |  Card: #FFFFFF  |  Low: #F9F8F6  |  Mid: #F2F0ED  |  High: #ECE9E5
        Text:   #1C1917  |  Muted: #78716C  |  Border: #E7E5E4
        Gold:   #D4A84B (warm gold) primary  |  #EAB308 (digital gold) container/accent
    -->

    <Color x:Key="PrimaryColor">#D4A84B</Color>
    <Color x:Key="PrimaryContainerColor">#EAB308</Color>
    <Color x:Key="PrimaryHoverColor">#C8923A</Color>
    <Color x:Key="OnPrimaryColor">#1C1917</Color>

    <Color x:Key="SurfaceColor">#FAFAF9</Color>
    <Color x:Key="SurfaceContainerLowestColor">#FFFFFF</Color>
    <Color x:Key="SurfaceContainerLowColor">#F9F8F6</Color>
    <Color x:Key="SurfaceContainerColor">#F2F0ED</Color>
    <Color x:Key="SurfaceContainerHighColor">#ECE9E5</Color>

    <Color x:Key="OnSurfaceColor">#1C1917</Color>
    <Color x:Key="OnSurfaceVariantColor">#78716C</Color>

    <Color x:Key="OutlineColor">#78716C</Color>
    <Color x:Key="OutlineVariantColor">#E7E5E4</Color>
    <Color x:Key="DisabledSurfaceColor">#F2F0ED</Color>
    <Color x:Key="DisabledBorderColor">#E0DDD9</Color>
    <Color x:Key="DisabledForegroundColor">#B0A99F</Color>

    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="OnErrorSurfaceColor">#7F1D1D</Color>

    <!-- Gradient kept for card-tone use; primary buttons now use flat solid brush -->
    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientHoverBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryHoverColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%" x:Key="CardToneGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource SurfaceContainerLowColor}" />
        <GradientStop Offset="1" Color="{StaticResource SurfaceContainerColor}" />
    </LinearGradientBrush>

    <SolidColorBrush Color="{StaticResource PrimaryColor}"    x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryHoverColor}" x:Key="PrimaryHoverBrush" />
    <SolidColorBrush Color="{StaticResource OnPrimaryColor}"  x:Key="OnPrimaryBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceColor}"               x:Key="SurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="SurfaceLowestBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}"   x:Key="SurfaceContainerLowBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}"      x:Key="SurfaceContainerBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerHighColor}"  x:Key="SurfaceContainerHighBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="SurfaceBrightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}"        x:Key="OnSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="OnSurfaceVariantBrush" />

    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.5"  x:Key="OutlineVariantGhostBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}"        Opacity="0.25" x:Key="OutlineGhostBrush" />

    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}"   x:Key="TextPrimaryBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.6" x:Key="BorderBrush" />
    <SolidColorBrush Color="#BFD05D"                                  x:Key="SecondaryLightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}"   x:Key="SecondaryBrush" />

    <SolidColorBrush Color="#33D4A84B" x:Key="PrimaryGoldTransparent" />
    <SolidColorBrush Color="#44D4A84B" x:Key="TextSelectionBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="TextSelectionForegroundBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}"  x:Key="AppSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}"     x:Key="AppSurfaceAltBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}"   Opacity="0.25" x:Key="AppEmphasisBorderBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.7" x:Key="AppBorderSubtleBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}"           x:Key="AppBorderBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceColor}"            x:Key="AuthPageBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}"   x:Key="AuthCardBackgroundBrush" />
    <SolidColorBrush Color="Transparent"                              x:Key="AuthCardBorderBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}" Opacity="0.1"  x:Key="AuthErrorBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}" Opacity="0.2"  x:Key="AuthErrorBorderBrush" />
    <SolidColorBrush Color="{StaticResource OnErrorSurfaceColor}"     x:Key="AuthErrorForegroundBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryContainerColor}"   x:Key="AuthLinkBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceColor}"            x:Key="AppBackgroundBrush" />

    <!-- TextBox inputs: white fill, warm-gold tint border, amber on focus -->
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="TextBoxSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}"         x:Key="TextBoxBorderBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}"              x:Key="TextBoxHoverBorderBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryContainerColor}"       x:Key="TextBoxFocusBorderBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}"                x:Key="TextBoxPlaceholderBrush" />
    <SolidColorBrush Color="{StaticResource DisabledSurfaceColor}"        x:Key="TextBoxDisabledSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource DisabledBorderColor}"         x:Key="TextBoxDisabledBorderBrush" />
    <SolidColorBrush Color="{StaticResource DisabledForegroundColor}"     x:Key="TextBoxDisabledForegroundBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}"                  x:Key="TextBoxErrorBorderBrush" />
    <SolidColorBrush Color="{StaticResource OnErrorSurfaceColor}"         x:Key="TextBoxErrorForegroundBrush" />

    <Color x:Key="ShopDetailSidebarDarkColor">#2A241E</Color>
    <SolidColorBrush Color="{StaticResource ShopDetailSidebarDarkColor}"  x:Key="ShopDetailSidebarDarkBrush" />
    <SolidColorBrush Color="#F3E8DC"                                      x:Key="ShopDetailSidebarOnDarkBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryContainerColor}"       x:Key="ShopDetailSidebarAccentBrush" />
    <SolidColorBrush Color="#16A34A"                                      x:Key="ShopDetailOpenDotBrush" />
</ResourceDictionary>
