<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Surface">#1C1917</Color>
    <Color x:Key="SurfaceBright">#292524</Color>
    <Color x:Key="SurfaceContainer">#44403C</Color>

    <Color x:Key="OnSurface">#F5F5F4</Color>

    <Color x:Key="PrimaryGold">#EAB308</Color>
    <Color x:Key="PrimaryGoldHover">#CA8A04</Color>
    <Color x:Key="PrimaryGoldTransparent">#4DCA8A04</Color>

    <Color x:Key="NeutralDark">#A8A29E</Color>
    <Color x:Key="BorderDark">#57534E</Color>

    <SolidColorBrush Color="{StaticResource PrimaryGold}" x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryGoldHover}" x:Key="PrimaryHoverBrush" />
    <SolidColorBrush Color="{StaticResource NeutralDark}" x:Key="TextPrimaryBrush" />
    <SolidColorBrush Color="{StaticResource BorderDark}" x:Key="BorderBrush" />

    <SolidColorBrush Color="{StaticResource PrimaryGoldTransparent}" x:Key="TextSelectionBrush" />
    <SolidColorBrush Color="{StaticResource OnSurface}" x:Key="TextSelectionForegroundBrush" />
    <SolidColorBrush Color="{StaticResource OnSurface}" x:Key="OnSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource Surface}" x:Key="SurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceBright}" x:Key="SurfaceBrightBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainer}" x:Key="SurfaceContainerBrush" />

</ResourceDictionary>
