<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Midnight surfaces; canonical digital gold (#EAB308) primary, warm gold (#D4A84B) container. -->

    <Color x:Key="PrimaryColor">#EAB308</Color>
    <Color x:Key="PrimaryContainerColor">#D4A84B</Color>
    <Color x:Key="PrimaryHoverColor">#FACC15</Color>
    <Color x:Key="OnPrimaryColor">#1A1412</Color>

    <Color x:Key="SurfaceColor">#161311</Color>
    <Color x:Key="SurfaceContainerLowestColor">#100E0C</Color>
    <Color x:Key="SurfaceContainerLowColor">#201B13</Color>
    <Color x:Key="SurfaceContainerColor">#2A241E</Color>
    <Color x:Key="SurfaceContainerHighColor">#362F27</Color>

    <Color x:Key="OnSurfaceColor">#FBEFE2</Color>
    <Color x:Key="OnSurfaceVariantColor">#D5C4AE</Color>

    <Color x:Key="OutlineColor">#9E8E7B</Color>
    <Color x:Key="OutlineVariantColor">#514535</Color>
    <Color x:Key="DisabledSurfaceColor">#100E0C</Color>
    <Color x:Key="DisabledBorderColor">#3D3832</Color>
    <Color x:Key="DisabledForegroundColor">#6B635C</Color>

    <Color x:Key="ErrorColor">#FFB4AB</Color>
    <Color x:Key="OnErrorSurfaceColor">#690005</Color>

    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%" x:Key="PrimaryGradientHoverBrush">
        <GradientStop Offset="0" Color="{StaticResource PrimaryHoverColor}" />
        <GradientStop Offset="1" Color="{StaticResource PrimaryContainerColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%" x:Key="CardToneGradientBrush">
        <GradientStop Offset="0" Color="{StaticResource SurfaceContainerLowColor}" />
        <GradientStop Offset="1" Color="{StaticResource SurfaceContainerColor}" />
    </LinearGradientBrush>

    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryHoverColor}" x:Key="PrimaryHoverBrush" />
    <SolidColorBrush Color="{StaticResource OnPrimaryColor}" x:Key="OnPrimaryBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceColor}" x:Key="SurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="SurfaceLowestBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="SurfaceContainerLowBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="SurfaceContainerBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerHighColor}" x:Key="SurfaceContainerHighBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="SurfaceBrightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="OnSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="OnSurfaceVariantBrush" />

    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.15" x:Key="OutlineVariantGhostBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}" Opacity="0.2" x:Key="OutlineGhostBrush" />

    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="TextPrimaryBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.08" x:Key="BorderBrush" />
    <SolidColorBrush Color="#BFD05D" x:Key="SecondaryLightBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceVariantColor}" x:Key="SecondaryBrush" />

    <SolidColorBrush Color="#66BFD05D" x:Key="PrimaryGoldTransparent" />
    <SolidColorBrush Color="#55BFD05D" x:Key="TextSelectionBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="TextSelectionForegroundBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="AppSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerColor}" x:Key="AppSurfaceAltBrush" />
    <SolidColorBrush Color="{StaticResource OutlineColor}" Opacity="0.2" x:Key="AppEmphasisBorderBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.15" x:Key="AppBorderSubtleBrush" />
    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.12" x:Key="AppBorderBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceColor}" x:Key="AuthPageBackgroundBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="AuthCardBackgroundBrush" />
    <SolidColorBrush Color="Transparent" x:Key="AuthCardBorderBrush" />
    <SolidColorBrush Color="#33FFB4AB" x:Key="AuthErrorBackgroundBrush" />
    <SolidColorBrush Color="#44FFB4AB" x:Key="AuthErrorBorderBrush" />
    <SolidColorBrush Color="{StaticResource OnErrorSurfaceColor}" x:Key="AuthErrorForegroundBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="AuthLinkBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceColor}" x:Key="AppBackgroundBrush" />

    <!-- TextBox / text inputs (same state model as light; surfaces lifted on dark) -->
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowColor}" x:Key="TextBoxSurfaceBrush" />
    <SolidColorBrush Color="#6B6055" x:Key="TextBoxBorderBrush" />
    <SolidColorBrush Color="#E9E1DD" x:Key="TextBoxHoverBorderBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="TextBoxFocusBorderBrush" />
    <SolidColorBrush Color="#9A8F82" x:Key="TextBoxPlaceholderBrush" />
    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="TextBoxDisabledSurfaceBrush" />
    <SolidColorBrush Color="{StaticResource DisabledBorderColor}" x:Key="TextBoxDisabledBorderBrush" />
    <SolidColorBrush Color="{StaticResource DisabledForegroundColor}" x:Key="TextBoxDisabledForegroundBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}" x:Key="TextBoxErrorBorderBrush" />
    <SolidColorBrush Color="{StaticResource ErrorColor}" x:Key="TextBoxErrorForegroundBrush" />

    <SolidColorBrush Color="{StaticResource SurfaceContainerLowestColor}" x:Key="ShopDetailSidebarDarkBrush" />
    <SolidColorBrush Color="{StaticResource OnSurfaceColor}" x:Key="ShopDetailSidebarOnDarkBrush" />
    <SolidColorBrush Color="{StaticResource PrimaryColor}" x:Key="ShopDetailSidebarAccentBrush" />
    <SolidColorBrush Color="#81C784" x:Key="ShopDetailOpenDotBrush" />
</ResourceDictionary>
