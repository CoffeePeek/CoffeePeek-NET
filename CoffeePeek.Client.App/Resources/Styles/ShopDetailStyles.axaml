<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.shop-detail-hero">
        <Setter Property="Height" Value="300" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="CornerRadius" Value="0,0,32,32" />
    </Style>

    <Style Selector="Border.shop-detail-chip">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Margin" Value="0,0,8,8" />
    </Style>

    <Style Selector="Border.shop-detail-chip TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Border.shop-detail-sidebar-card">
        <Setter Property="Background" Value="{DynamicResource ShopDetailSidebarDarkBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.shop-detail-map-stub">
        <Setter Property="Height" Value="148" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Border.shop-detail-quick-info">
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="PathIcon.shop-detail-quick-icon">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style Selector="Border.shop-detail-reviews-card">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

</Styles>
