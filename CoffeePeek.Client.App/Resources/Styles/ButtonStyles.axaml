<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Thickness x:Key="ButtonPadding">12, 8</Thickness>
    </Styles.Resources>

    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="8">
                <Button Classes="Primary" Content="Primary" />
                <Button Classes="Secondary" Content="Secondary" />
                <Button Classes="Transparent" Content="Transparent" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="20 10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource LargeRadius}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{StaticResource Sora}" />
        <Setter Property="BorderThickness" Value="{StaticResource DefaultThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource DefaultThickness}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderColor}" />
    </Style>

    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
    </Style>


    <Style Selector="Button.Transparent">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.Transparent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
</Styles>
