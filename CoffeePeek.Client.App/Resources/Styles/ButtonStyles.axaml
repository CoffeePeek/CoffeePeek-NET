<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Thickness x:Key="ButtonPadding">12, 8</Thickness>
    </Styles.Resources>

    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="8">
                <Button Content="Primary" />
                <Button Classes="Secondary" Content="Secondary" />
                <Button Classes="Transparent" Content="Transparent" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!--  Primary: Saffron gradient, on_primary label  -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryGradientBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="FontFamily" Value="{StaticResource RFDewiExpanded}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryGradientHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
    </Style>

    <!--  Secondary: ghost + outline whisper  -->
    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource OutlineGhostBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource OutlineGhostBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style Selector="Button.Transparent">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style Selector="Button.Transparent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryHoverBrush}" />
    </Style>
</Styles>
