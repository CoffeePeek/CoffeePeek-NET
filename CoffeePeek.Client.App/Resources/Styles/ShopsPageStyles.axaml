<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.filter-chip">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox.filter-chips">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem Border.filter-chip">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem Border.filter-chip TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:pointerover Border.filter-chip">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:pointerover Border.filter-chip TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:selected Border.filter-chip">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:selected Border.filter-chip TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:selected:pointerover Border.filter-chip">
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
    </Style>

    <Style Selector="ListBox.filter-chips ListBoxItem:selected:pointerover Border.filter-chip TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
    </Style>

    <Style Selector="Border.shop-card">
        <Setter Property="Width" Value="280" />
        <Setter Property="Margin" Value="0,0,16,20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource LargeRadius}" />
    </Style>

    <Style Selector="Button.shop-card-host">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.shop-card-host:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.shop-card-host:pointerover Border.shop-card">
        <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantGhostBrush}" />
    </Style>
</Styles>
