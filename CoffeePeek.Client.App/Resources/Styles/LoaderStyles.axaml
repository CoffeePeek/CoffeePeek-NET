<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ═══════════════════════════════════════════════════════
    GOO TRIO LOADER (02) — three blobs oscillating organically
    Canvas is 160×160; center = (80, 80).

    Blob positions (Left, Top) computed from center offsets:
      Blob 1 (64×64): center moves (36,80) ↔ (124,80), Left = center_x−32
      Blob 2 (64×64): center moves (124,80) ↔ (36,80), Left = center_x−32
      Blob 3 (40×40): center moves (80,108) ↔ (80,52), Top  = center_y−20
    ═══════════════════════════════════════════════════════
    -->

    <!-- Blob 1: gold, oscillates left ↔ right over 3 s -->
    <Style Selector="Ellipse.goo-blob-1">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Style.Animations>
            <Animation Duration="0:0:3" IterationCount="INFINITE" Easing="SineEaseInOut" FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="(Canvas.Left)" Value="4" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="(Canvas.Left)" Value="92" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="(Canvas.Left)" Value="4" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Blob 2: amber, oscillates right ↔ left (anti-phase), 3 s -->
    <Style Selector="Ellipse.goo-blob-2">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Style.Animations>
            <Animation Duration="0:0:3" IterationCount="INFINITE" Easing="SineEaseInOut" FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="(Canvas.Left)" Value="92" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="(Canvas.Left)" Value="4" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="(Canvas.Left)" Value="92" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Blob 3: warm gold, oscillates down ↔ up, 3 s -->
    <Style Selector="Ellipse.goo-blob-3">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Style.Animations>
            <Animation Duration="0:0:3" IterationCount="INFINITE" Easing="SineEaseInOut" FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="(Canvas.Top)" Value="88" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="(Canvas.Top)" Value="32" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="(Canvas.Top)" Value="88" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!--
    ═══════════════════════════════════════════════════════
    WOBBLE RING LOADER (11) — spinning partial arc
    StrokeDashArray="56,19" shows ~75 % of the arc for a 20×20 ring.
    RotateTransform animates from 0° → 360° in 1.6 s with easing.
    ═══════════════════════════════════════════════════════
    -->
    <Style Selector="Ellipse.wobble-ring">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Style.Animations>
            <Animation Duration="0:0:1.6" IterationCount="INFINITE" Easing="CubicEaseInOut" FillMode="None">
                <KeyFrame Cue="0%">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="0" />
                        </Setter.Value>
                    </Setter>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="360" />
                        </Setter.Value>
                    </Setter>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
