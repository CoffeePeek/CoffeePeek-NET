<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel>
                <Border
                    Classes="Card"
                    Height="100"
                    Width="100" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{DynamicResource PrimaryGoldTransparent}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</Styles>
