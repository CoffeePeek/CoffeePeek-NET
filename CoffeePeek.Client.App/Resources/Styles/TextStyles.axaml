<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20" Background="{DynamicResource SurfaceBrush}">
            <StackPanel Spacing="8">
                <TextBlock Classes="Display" Text="Display" />
                <TextBlock Classes="Headline" Text="Headline" />
                <TextBlock Classes="Title" Text="Title" />
                <TextBlock Classes="Body" Text="Body" />
                <TextBlock Classes="BodySmall" Text="Body small" />
                <TextBlock Classes="Caption" Text="Caption" />
                <TextBlock Classes="Eyebrow" Text="Eyebrow label" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Base: RF Dewi Expanded throughout, on-surface colour -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource RFDewiExpanded}" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <!--  Display: 48 px / ExtraBold — hero numbers, big callouts  -->
    <Style Selector="TextBlock.Display">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="LineHeight" Value="52" />
        <Setter Property="LetterSpacing" Value="-0.025" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <!--  Headline: 24 px / Bold — section headings, card titles  -->
    <Style Selector="TextBlock.Headline">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="30" />
        <Setter Property="LetterSpacing" Value="-0.02" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <!--  Title: 20 px / SemiBold — sub-section headings  -->
    <Style Selector="TextBlock.Title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="28" />
        <Setter Property="LetterSpacing" Value="-0.01" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <!--  Body: 16 px / Regular — main readable content  -->
    <Style Selector="TextBlock.Body">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
    </Style>

    <!--  BodySmall: 14 px / Regular — secondary content, meta  -->
    <Style Selector="TextBlock.BodySmall">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
    </Style>

    <!--  Label: 12 px / Medium — compact labels, tags  -->
    <Style Selector="TextBlock.Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
    </Style>

    <!--  Caption: 12 px / Normal — helper text, timestamps  -->
    <Style Selector="TextBlock.Caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
    </Style>

    <!--  Eyebrow: 11 px / Bold ALL-CAPS — section labels, status badges (uppercase applied in view content)  -->
    <Style Selector="TextBlock.Eyebrow">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LetterSpacing" Value="0.08" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <!--  Secondary: muted variant for any class  -->
    <Style Selector="TextBlock.Secondary">
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="FontFamily" Value="{StaticResource RFDewiExpanded}" />
    </Style>
</Styles>
