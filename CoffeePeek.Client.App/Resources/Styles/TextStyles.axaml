<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="8">
                <TextBlock Classes="Headline" Text="Headline" />
                <TextBlock Classes="Body" Text="Body" />
                <TextBlock Classes="Label" Text="Label" />
            </StackPanel>

        </Border>
    </Design.PreviewWith>

    <Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Sora}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.Headline">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
        </Style>

        <Style Selector="TextBlock.Body">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="LineHeight" Value="21" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}" />
        </Style>

        <Style Selector="TextBlock.Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="FontFamily" Value="{StaticResource Sora}" />
        </Style>
    </Styles>

</Styles>
