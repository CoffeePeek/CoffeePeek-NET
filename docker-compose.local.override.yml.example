    environment:
      - ASPNETCORE_ENVIRONMENT=Development

  moderationservice:
    environment:
      - ASPNETCORE_ENVIRONMENT=Development

  jobvacancies:
    environment:
      - ASPNETCORE_ENVIRONMENT=Development

  gateway:
    environment:
      - ASPNETCORE_ENVIRONMENT=Development