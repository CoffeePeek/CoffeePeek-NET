{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "JWTOptions": {
    "SecretKey": "",
    "AccessTokenLifetimeMinutes": "",
    "RefreshTokenLifetimeDays": "",
    "Audience": "CoffeePeek.API",
    "Issuer": "CoffeePeek.WEB"
  },
  "ReverseProxy": {
    "Routes": {
      "account-Tokens-route": {
        "ClusterId": "account-cluster",
        "Match": { "Path": "/api/Tokens/{**remainder}" }
      },
      "account-Users-route": {
        "ClusterId": "account-cluster",
        "Match": { "Path": "/api/Users/{**remainder}" }
      },
      "account-admin-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "Admin",
        "Match": { "Path": "/api/admin/{**remainder}" }
      },
      "account-openapi-route": {
        "ClusterId": "account-cluster",
        "Match": { "Path": "/account/openapi/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/account" }
        ]
      },

      "shops-Catalogs-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/Catalogs/{**remainder}" }
      },
      "shops-CheckIns-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/CheckIns/{**remainder}" }
      },
      "shops-CoffeeShops-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/CoffeeShops/{**remainder}" }
      },
      "shops-CoffeeShopReviews-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/CoffeeShopReviews/{**remainder}" }
      },
      "shops-FavoriteCoffeeShops-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/FavoriteCoffeeShops/{**remainder}" }
      },
      "shops-Map-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/Map/{**remainder}" },
        "RateLimiterPolicy": "global"
      },
      "shops-UserReviews-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/UserReviews/{**remainder}" }
      },
      "shops-users-reviews-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/api/users/{userId}/reviews" }
      },
      "shops-openapi-route": {
        "ClusterId": "shops-cluster",
        "Match": { "Path": "/shops/openapi/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/shops" }
        ]
      },

      "moderation-Moderation-route": {
        "ClusterId": "moderation-cluster",
        "Match": { "Path": "/api/Moderation/{**remainder}" }
      },
      "moderation-ModerationReviews-route": {
        "ClusterId": "moderation-cluster",
        "Match": { "Path": "/api/ModerationReviews/{**remainder}" }
      },
      "moderation-ModerationShops-route": {
        "ClusterId": "moderation-cluster",
        "Match": { "Path": "/api/ModerationShops/{**remainder}" }
      },
      "moderation-openapi-route": {
        "ClusterId": "moderation-cluster",
        "Match": { "Path": "/moderation/openapi/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/moderation" }
        ]
      },

      "media-Photos-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/api/Photos/{**remainder}" }
      },
      "media-openapi-route": {
        "ClusterId": "media-cluster",
        "Match": { "Path": "/media/openapi/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/media" }
        ]
      }
    },
    "Clusters": {
      "account-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://coffeepeekaccountservice.railway.internal"
          }
        }
      },
      "shops-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://coffeepeekshopsservice.railway.internal"
          }
        }
      },
      "moderation-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://coffeepeekmoderationservice.railway.internal"
          }
        }
      },
      "media-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://coffeepeekmediaservice.railway.internal"
          }
        }
      }
    }
  }
}
