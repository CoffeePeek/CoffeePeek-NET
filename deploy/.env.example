# Public API domain (used by Caddy for HTTPS)
DOMAIN=api.coffeepeek.by
ACME_EMAIL=you@example.com

# Gateway port when running without Caddy (http://VPS_IP:8080)
GATEWAY_PORT=8080

# Docker images — use Docker Hub from CI, or "coffeepeek" for local builds
DOCKER_IMAGE_PREFIX=docker.io/YOUR_DOCKERHUB_USERNAME
IMAGE_TAG=dev

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Redis
REDIS_PASSWORD=change-me-strong-redis-password

# RabbitMQ
RABBITMQ_USER=coffeepeek
RABBITMQ_PASSWORD=change-me-strong-rabbitmq-password
# Use "/" for fresh VPS; use "/prod" if migrating from Railway with same vhost
RABBITMQ_VHOST=/

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=coffeepeek
MINIO_ROOT_PASSWORD=change-me-strong-minio-password

# JWT (must match across gateway + account service)
JWT_SECRET_KEY=change-me-at-least-32-characters-long-secret
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=30

# External services
RESEND_API_TOKEN=
WEB_CLIENT_URL=https://coffeepeek.by
SENTRY_DSN=
YANDEX_GEOCODER_API_KEY=

# --- Railway migration (optional, for import-railway-data.sh) ---
RAILWAY_PG_HOST=
RAILWAY_PG_PORT=
RAILWAY_PG_USER=postgres
RAILWAY_PG_PASSWORD=
